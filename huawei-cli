}

# =============================================================================
# CAMERA
# =============================================================================
cmd_camera() {
    local sub="${1:-status}"
    shift 2>/dev/null || true

    case "$sub" in
        status)
            hdr "Camera"
            if lsmod | grep -q "intel_ipu6"; then
                ok "intel_ipu6 module loaded"
            else
                err "intel_ipu6 not loaded"
            fi
            if [[ -f /usr/lib/libcamhal/plugins/ipu6epmtl.so ]]; then
                ok "Camera HAL plugin installed"
            else
                err "Camera HAL plugin missing"
            fi
            if dmesg 2>/dev/null | grep -q "INT3472.*EBUSY"; then
                warn "INT3472 GPIO conflict detected in dmesg — streaming blocked (upstream bug)"
                dim "  Track: https://github.com/intel/ipu6-drivers/issues/399"
            else
                info "No INT3472 error in dmesg (camera may be functional)"
            fi
            echo ""
            info "V4L2 devices:"
            ls /dev/video* 2>/dev/null | sed 's/^/  /' || echo "  None found"
            ;;

        test)
            info "Testing camera pipeline via GStreamer (Ctrl+C to stop)..."
            warn "This will fail on VGHH-XX while INT3472 bug is unresolved."
            sudo -E gst-launch-1.0 icamerasrc ! fakesink 2>&1 | head -20
            ;;

        dmesg)
            info "Camera-related kernel messages:"
            dmesg 2>/dev/null | grep -iE "ipu6|INT3472|OV13B10|OV01A1S|icamera" | tail -30 | sed 's/^/  /'
            ;;

        *)
            err "Unknown camera subcommand: $sub"
            echo "Usage: huawei camera {status|test|dmesg}"
            exit 1
            ;;
    esac
}

# =============================================================================
# UPDATES — track known upstream issues and local fix status
# =============================================================================

# Cache TTL in seconds (default 6 hours; override with HUAWEI_CACHE_TTL)
_CACHE_TTL="${HUAWEI_CACHE_TTL:-21600}"
_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/huawei-cli"
_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/huawei-cli"
_USER_ISSUES_FILE="$_CONFIG_DIR/tracked-issues"

# Built-in tracked items — format: "type:ref|label"
#   type github  → ref = owner/repo/number
#   type kernel  → ref = minimum kernel version where fix landed
#   type package → ref = package name to check for updates
#   type local   → ref = script function name
_BUILTIN_ITEMS=(
    "github:intel/ipu6-drivers/399|Camera: INT3472 GPIO conflict (VGHH-XX webcam blocked)"
    "local:_check_fingerprint|Fingerprint: Goodix sensor Linux driver support"
    "kernel:6.12|Kernel: minimum recommended for touchpad regression fix"
    "package:linux-image-generic-hwe-24.04|Kernel: HWE track updates available"
    "package:libcamhal-ipu6epmtl|Camera HAL: ipu6epmtl updates available"
)

# --- Cache helpers -----------------------------------------------------------
_cache_key()  { echo "${1//\//_}" | tr ':' '_'; }

_cache_read() {
    local key
    key=$(_cache_key "$1")
    local f="$_CACHE_DIR/${key}.json" ts="$_CACHE_DIR/${key}.ts"
    [[ -f "$f" && -f "$ts" ]] || return 1
    local age=$(( $(date +%s) - $(cat "$ts") ))
    [[ "$age" -lt "$_CACHE_TTL" ]] || return 1
    cat "$f"
}

_cache_write() {
    local key data
    key=$(_cache_key "$1"); data="$2"
    mkdir -p "$_CACHE_DIR"
    echo "$data" > "$_CACHE_DIR/${key}.json"
    date +%s      > "$_CACHE_DIR/${key}.ts"
}

# --- JSON field extractor (python3 — no jq dependency) ----------------------
_jq() {
    local field="$1"
    python3 -c "
import json,sys
try:
    d=json.load(sys.stdin)
    v=d.get('$field','')
    print(v if v is not None else '')
except Exception:
    print('')
"
}

# --- GitHub issue fetch ------------------------------------------------------
# Returns: "STATE|TITLE|UPDATED_AT|COMMENTS|HTML_URL"
_gh_issue() {
    local owner="$1" repo="$2" number="$3"
    local ref="$owner/$repo/$number"

    local json
    if ! json=$(_cache_read "$ref"); then
        json=$(curl -sf --max-time 10 \
            -H "Accept: application/vnd.github.v3+json" \
            -H "User-Agent: huawei-cli/1.0" \
            "https://api.github.com/repos/${owner}/${repo}/issues/${number}") \
            || { echo "FETCH_ERROR|||"; return 1; }
        _cache_write "$ref" "$json"
    fi

    local state title updated comments url
    state=$(   echo "$json" | _jq state)
    title=$(   echo "$json" | _jq title)
    updated=$( echo "$json" | _jq updated_at)
    comments=$(echo "$json" | _jq comments)
    url=$(     echo "$json" | _jq html_url)

    echo "${state}|${title}|${updated}|${comments}|${url}"
}

# --- Render a single issue row -----------------------------------------------
_show_gh_item() {
    local ref="$1" label="$2"
    local owner repo number
    IFS='/' read -r owner repo number <<< "$ref"

    echo -e "\n  ${BLD}${label}${RST}"
    dim "  github.com/${owner}/${repo}/issues/${number}"

    local result
    if ! result=$(_gh_issue "$owner" "$repo" "$number"); then
        warn "  Could not fetch — check your internet connection"
        return
    fi

    local state title updated comments url
    IFS='|' read -r state title updated comments url <<< "$result"

    local state_col state_sym
    case "$state" in
        closed) state_col="$GRN"; state_sym="✓ closed" ;;
        open)   state_col="$RED"; state_sym="● open"   ;;
        *)      state_col="$CYN"; state_sym="? $state"  ;;
    esac

    echo -e "  Status  : ${state_col}${BLD}${state_sym}${RST}"
    [[ -n "$title"    ]] && echo -e "  Title   : $title"
    [[ -n "$updated"  ]] && echo -e "  Updated : ${updated%T*}"
    [[ -n "$comments" ]] && echo -e "  Comments: $comments"
    [[ -n "$url"      ]] && dim "  $url"
}

# --- Local checks ------------------------------------------------------------
_check_fingerprint() {
    echo -e "\n  ${BLD}Fingerprint: Goodix sensor Linux driver support${RST}"

    # Find fingerprint USB device (Goodix VID = 27c6, common MateBook PIDs)
    local fp_usb
    fp_usb=$(lsusb 2>/dev/null | grep -i "27c6" || true)

    if [[ -z "$fp_usb" ]]; then
        dim "  No Goodix USB fingerprint device found on USB bus"
        return
    fi

    echo -e "  Device  : $fp_usb"

    # Extract VID:PID for libfprint check
    local vidpid
    vidpid=$(echo "$fp_usb" | grep -oP '27c6:[0-9a-fA-F]{4}' | head -1)

    # Check if fprintd sees any enrolled/available devices
    if command -v fprintd-list &>/dev/null; then
        local fp_out
        fp_out=$(fprintd-list "$USER" 2>&1 || true)
        if echo "$fp_out" | grep -qi "no devices"; then
            echo -e "  Status  : ${RED}${BLD}● not supported${RST}  (fprintd: no devices)"
        elif echo "$fp_out" | grep -qi "error\|no enrolled"; then
            echo -e "  Status  : ${YLW}${BLD}! driver present but no enrolled fingers${RST}"
        else
            echo -e "  Status  : ${GRN}${BLD}✓ may be working — check fprintd-list${RST}"
        fi
    else
        echo -e "  Status  : ${YLW}! fprintd not installed — cannot check${RST}"
    fi

    # Check libfprint supported device list
    local fp_lib
    fp_lib=$(find /usr/lib -name "libfprint*.so*" 2>/dev/null | head -1)
    if [[ -n "$vidpid" && -n "$fp_lib" ]]; then
        if strings "$fp_lib" 2>/dev/null | grep -qi "${vidpid,,}"; then
            ok "  $vidpid found in libfprint device strings"
        else
            warn "  $vidpid not found in libfprint — driver likely missing"
        fi
    fi

    dim "  libfprint issues: https://gitlab.freedesktop.org/libfprint/libfprint/-/issues"
}

# --- Kernel version check ----------------------------------------------------
_show_kernel_item() {
    local min_ver="$1" label="$2"
    echo -e "\n  ${BLD}${label}${RST}"
    local running
    running=$(uname -r | grep -oP '^\d+\.\d+')
    local min_major min_minor run_major run_minor
    IFS='.' read -r min_major min_minor <<< "$min_ver"
    IFS='.' read -r run_major run_minor <<< "$running"

    echo -e "  Running : $running  (minimum: $min_ver)"

    if [[ "$run_major" -gt "$min_major" ]] || \
       { [[ "$run_major" -eq "$min_major" ]] && [[ "$run_minor" -ge "$min_minor" ]]; }; then
        ok "  Kernel meets minimum requirement"
    else
        warn "  Kernel ${running} is below minimum ${min_ver} — consider upgrading"
    fi
}

# --- Package update check ----------------------------------------------------
_show_package_item() {
    local pkg="$1" label="$2"
    echo -e "\n  ${BLD}${label}${RST}"

    if ! dpkg -l "$pkg" &>/dev/null; then
        warn "  $pkg is not installed"
        return
    fi

    local installed available
    installed=$(dpkg -l "$pkg" 2>/dev/null | awk '/^ii/{print $3}')
    echo -e "  Installed: $installed"

    # Check apt cache for newer version (no network hit if cache is stale)
    available=$(apt-cache policy "$pkg" 2>/dev/null \
        | awk '/Candidate:/{print $2}')

    if [[ -n "$available" && "$available" != "$installed" ]]; then
        echo -e "  Available: ${YLW}${BLD}$available${RST}  ← update available"
        dim "  Run: sudo apt install $pkg"
    else
        ok "  Up to date${available:+  ($available)}"
    fi
}

# --- Load user-defined issues ------------------------------------------------
_user_items() {
    [[ -f "$_USER_ISSUES_FILE" ]] || return 0
    grep -v '^\s*#' "$_USER_ISSUES_FILE" | grep -v '^\s*$' || true
}

# --- Parse a GitHub URL into owner/repo/number -------------------------------
_parse_gh_url() {
    local url="$1"
    # Accept:  https://github.com/owner/repo/issues/123
    #          github.com/owner/repo/issues/123
    #          owner/repo#123  or  owner/repo/123
    url="${url#https://github.com/}"
    url="${url#github.com/}"
    # owner/repo/issues/N or owner/repo#N
    if [[ "$url" =~ ^([^/]+)/([^/]+)/issues/([0-9]+) ]]; then
        echo "${BASH_REMATCH[1]}/${BASH_REMATCH[2]}/${BASH_REMATCH[3]}"
    elif [[ "$url" =~ ^([^/]+)/([^#]+)#([0-9]+) ]]; then
        echo "${BASH_REMATCH[1]}/${BASH_REMATCH[2]}/${BASH_REMATCH[3]}"
    else
        echo ""
    fi
}

# --- Main updates command ----------------------------------------------------
cmd_updates() {
    local sub="${1:-check}"
    shift 2>/dev/null || true

    case "$sub" in
        check|c)
            local no_cache=false
            [[ "${1:-}" == "--no-cache" || "${1:-}" == "-f" ]] && no_cache=true

            if $no_cache; then
                rm -rf "$_CACHE_DIR"
                info "Cache cleared — fetching fresh data..."
            fi

            hdr "Upstream Issue Tracker"
            local user_count=0
            [[ -f "$_USER_ISSUES_FILE" ]] && user_count=$(grep -c '.' "$_USER_ISSUES_FILE" 2>/dev/null || echo 0)
            echo -e "  ${DIM}Checking ${#_BUILTIN_ITEMS[@]} built-in items + ${user_count} user items${RST}"
            echo -e "  ${DIM}Cache TTL: $(( _CACHE_TTL / 3600 ))h  |  Clear with: huawei updates check --no-cache${RST}"

            # Built-in items
            for item in "${_BUILTIN_ITEMS[@]}"; do
                local type_ref label
                IFS='|' read -r type_ref label <<< "$item"
                local itype iref
                IFS=':' read -r itype iref <<< "$type_ref"

                case "$itype" in
                    github)  _show_gh_item "$iref" "$label" ;;
                    kernel)  _show_kernel_item "$iref" "$label" ;;
                    package) _show_package_item "$iref" "$label" ;;
                    local)   "$iref" ;;
                esac
            done

            # User-defined items
            local user_items
            mapfile -t user_items < <(_user_items)
            for line in "${user_items[@]}"; do
                local ref label
                IFS='|' read -r ref label <<< "$line"
                label="${label:-$ref}"
                local parsed
                parsed=$(_parse_gh_url "$ref")
                if [[ -n "$parsed" ]]; then
                    _show_gh_item "$parsed" "$label"
                else
                    warn "Cannot parse issue ref: $ref"
                fi
            done

            echo ""
            ;;

        add)
            local url="${1:-}"
            [[ -n "$url" ]] || die "Usage: huawei updates add <github-issue-url> [label]"
            local label="${2:-}"

            local parsed
            parsed=$(_parse_gh_url "$url")
            [[ -n "$parsed" ]] || die "Could not parse GitHub issue URL: $url"

            mkdir -p "$_CONFIG_DIR"
            local line="${url}"
            [[ -n "$label" ]] && line="${url}|${label}"
            echo "$line" >> "$_USER_ISSUES_FILE"
            ok "Added: $line"
            dim "  Stored in $_USER_ISSUES_FILE"
            ;;

        remove|rm)
            local url="${1:-}"
            [[ -n "$url" ]] || die "Usage: huawei updates remove <github-issue-url>"
            [[ -f "$_USER_ISSUES_FILE" ]] || die "No user issues file found."
            local escaped="${url//\//\\/}"
            sed -i "/^${escaped}/d" "$_USER_ISSUES_FILE"
            ok "Removed entries matching: $url"
            ;;

        list|ls)
            hdr "Tracked Issues"
            echo -e "  ${BLD}Built-in:${RST}"
            for item in "${_BUILTIN_ITEMS[@]}"; do
                local type_ref label
                IFS='|' read -r type_ref label <<< "$item"
                echo -e "    ${DIM}${type_ref}${RST}  $label"
            done
            echo -e "\n  ${BLD}User-defined${RST}  (${_USER_ISSUES_FILE}):"
            if [[ -f "$_USER_ISSUES_FILE" ]] && [[ -s "$_USER_ISSUES_FILE" ]]; then
                grep -v '^\s*#' "$_USER_ISSUES_FILE" | sed 's/^/    /'
            else
                dim "    (none — use: huawei updates add <github-url>)"
            fi
            echo ""
            ;;

        cache)
            local action="${1:-status}"
            case "$action" in
                clear) rm -rf "$_CACHE_DIR" && ok "Cache cleared" ;;
                status)
                    if [[ -d "$_CACHE_DIR" ]]; then
                        local count
                        count=$(ls "$_CACHE_DIR"/*.json 2>/dev/null | wc -l)
                        echo -e "  Cache dir  : $_CACHE_DIR"
                        echo -e "  Entries    : $count"
                        echo -e "  TTL        : $(( _CACHE_TTL / 3600 ))h  (override: HUAWEI_CACHE_TTL)"
                    else
                        dim "  No cache yet."
                    fi
                    ;;
            esac
            ;;

        *)
            err "Unknown updates subcommand: $sub"
            echo "Usage: huawei updates {check [--no-cache]|add <url> [label]|remove <url>|list|cache}"
            exit 1
            ;;
    esac
}

# =============================================================================
# INFO — system & model details
# =============================================================================
cmd_info() {
    hdr "System Information"
    echo -e "  Model    : ${BLD}$(dmidecode -s system-product-name 2>/dev/null || echo unknown)${RST}"
    echo -e "  BIOS     : $(dmidecode -s bios-version 2>/dev/null || echo unknown)"
    echo -e "  Kernel   : $(uname -r)"
    echo -e "  CPU      : $(grep 'model name' /proc/cpuinfo | head -1 | cut -d: -f2 | xargs)"
    echo -e "  Memory   : $(free -h | awk '/^Mem:/{print $2}') RAM"
    echo -e "  Uptime   : $(uptime -p)"

    hdr "Kernel Modules"
    local mods=(intel_ipu6 i2c_hid_acpi xe i915 snd_hda_intel btintel iwlwifi)
    for m in "${mods[@]}"; do
        if lsmod | grep -q "^${m}"; then
            ok "$m"
        else
            dim "  - $m (not loaded)"
        fi
    done

    hdr "PCI Devices (relevant)"
    lspci 2>/dev/null | grep -iE "display|audio|wireless|bluetooth|camera|thunderbolt" \
        | sed 's/^/  /' || echo "  lspci not available"
}

# =============================================================================
# THERMAL — CPU temperatures, fan speeds, throttle detection
# =============================================================================
cmd_thermal() {
    local sub="${1:-status}"
    shift 2>/dev/null || true

    # Find all hwmon devices with a name file
    _hwmon_dirs() { ls -d /sys/class/hwmon/hwmon* 2>/dev/null || true; }

    _hwmon_name() { sysread "$1/name"; }

    # Millidegrees → degrees
    _mdeg() { awk "BEGIN{printf \"%.1f\", $1/1000}"; }

    case "$sub" in
        status)
            hdr "Thermal"

            # --- CPU temperatures via coretemp / acpitz / intel_pch_thermal ---
            local printed_temp=false
            for hw in $(_hwmon_dirs); do
                local name
                name=$(_hwmon_name "$hw")
                case "$name" in
                    coretemp|acpitz|intel_pch_thermal|iwlwifi_1|BAT*)
                        for inp in "$hw"/temp*_input; do
                            [[ -f "$inp" ]] || continue
                            local raw label labelfile
                            raw=$(sysread "$inp")
                            labelfile="${inp/_input/_label}"
                            label=$(sysread "$labelfile")
                            label="${label:-$name}"
                            local deg
                            deg=$(_mdeg "$raw")
                            # Colour-code: green <70, yellow <85, red >=85
                            local col="$GRN"
                            (( ${raw%.*} >= 70000 )) && col="$YLW"
                            (( ${raw%.*} >= 85000 )) && col="$RED"
                            printf "  %-30s %b%s°C%b\n" "$label" "$col" "$deg" "$RST"
                            printed_temp=true
                        done
                        ;;
                esac
            done
            $printed_temp || warn "No temperature sensors found via hwmon"

            # --- Fan speeds ---
            echo ""
            local printed_fan=false
            for hw in $(_hwmon_dirs); do
                local hwname
                hwname=$(_hwmon_name "$hw")
                local fannum=0
                for fan in "$hw"/fan*_input; do
                    [[ -f "$fan" ]] || continue
                    (( fannum++ )) || true
                    local rpm labelfile label
                    rpm=$(sysread "$fan")
                    # Skip fans with no reading or 0 RPM (not present / stopped)
                    [[ -n "$rpm" && "$rpm" -gt 0 ]] 2>/dev/null || continue
                    labelfile="${fan/_input/_label}"
                    label=$(sysread "$labelfile")
                    # Fall back to "hwmon_name fan N" if label is empty
                    [[ -n "$label" ]] || label="${hwname} fan ${fannum}"
                    printf "  %-30s %s RPM\n" "$label" "$rpm"
                    printed_fan=true
                done
            done
            $printed_fan || dim "  No fan speed sensors found (or fans stopped)"

            # --- CPU frequency ---
            echo ""
            local min_mhz=999999 max_mhz=0 hw_max_mhz=0
            for f in /sys/devices/system/cpu/cpu*/cpufreq/scaling_cur_freq; do
                [[ -f "$f" ]] || continue
                local khz
                khz=$(sysread "$f")
                local mhz=$(( khz / 1000 ))
                (( mhz < min_mhz )) && min_mhz=$mhz
                (( mhz > max_mhz )) && max_mhz=$mhz
            done
            local hw_max_f="/sys/devices/system/cpu/cpu0/cpufreq/cpuinfo_max_freq"
            [[ -f "$hw_max_f" ]] && hw_max_mhz=$(( $(sysread "$hw_max_f") / 1000 ))

            if [[ "$max_mhz" -gt 0 ]]; then
                printf "  %-30s %d – %d MHz" "CPU frequency (all cores)" "$min_mhz" "$max_mhz"
                [[ "$hw_max_mhz" -gt 0 ]] && printf "  (hw max: %d MHz)" "$hw_max_mhz"
                echo ""
            fi

            # Turbo / no_turbo flag
            local no_turbo_f="/sys/devices/system/cpu/intel_pstate/no_turbo"
            if [[ -f "$no_turbo_f" ]]; then
                local nt
                nt=$(sysread "$no_turbo_f")
                if [[ "$nt" == "1" ]]; then
                    warn "Intel turbo boost is OFF  (no_turbo=1)"
                    dim "  Enable: echo 0 | sudo tee /sys/devices/system/cpu/intel_pstate/no_turbo"
                else
                    ok "Intel turbo boost enabled"
                fi
            fi
            ;;

        watch)
            local interval="${1:-2}"
            is_int "$interval" || interval=2
            echo -e "  ${DIM}Refreshing every ${interval}s — Ctrl+C to stop${RST}"
            while true; do
                clear
                cmd_thermal status
                sleep "$interval"
            done
            ;;

        *)
            err "Unknown thermal subcommand: $sub"
            echo "Usage: huawei thermal {status|watch [interval_secs]}"
            exit 1
            ;;
    esac
}

# =============================================================================
# KEYBOARD — backlight control
# =============================================================================
cmd_keyboard() {
    local sub="${1:-status}"
    shift 2>/dev/null || true

    # Discover keyboard backlight LED — try known paths in order
    _kb_led() {
        local candidates=(
            /sys/class/leds/huawei::kbd_backlight
            /sys/class/leds/huawei-wmi::kbd_backlight
            /sys/class/leds/ite829x::kbd_backlight
            /sys/class/leds/ite8291::kbd_backlight
        )
        # Also scan dynamically
        for d in /sys/class/leds/*/brightness; do
            local parent="${d%/brightness}"
            local name
            name=$(basename "$parent")
            case "${name,,}" in *kbd*|*keyboard*|*backlight*) candidates+=("$parent") ;; esac
        done
        for c in "${candidates[@]}"; do
            [[ -f "$c/brightness" ]] && { echo "$c"; return; }
        done
        echo ""
    }

    case "$sub" in
        status)
            hdr "Keyboard Backlight"
            local led
            led=$(_kb_led)
            if [[ -z "$led" ]]; then
                # Try loading huawei_wmi and re-check before giving up
                if ! lsmod | grep -q huawei_wmi; then
                    modprobe huawei_wmi 2>/dev/null || true
                    led=$(_kb_led)
                fi
                if [[ -z "$led" ]]; then
                    info "No keyboard backlight LED found (huawei_wmi loaded, no LED exposed)"
                    dim "  This model does not have a backlit keyboard"
                fi
                return
            fi
            local cur max
            cur=$(sysread "$led/brightness")
            max=$(sysread "$led/max_brightness")
            echo -e "  LED path : $led"
            echo -e "  Level    : ${BLD}${cur}${RST} / ${max}"
            [[ -f "$led/brightness_hw_changed" ]] && \
                dim "  Hardware key control supported"
            ;;

        set|level)
            need_root
            local val="${1:-}"
            [[ -n "$val" ]] || die "Usage: huawei keyboard set <level>"
            is_int "$val" || die "Level must be a non-negative integer."
            local led
            led=$(_kb_led)
            [[ -n "$led" ]] || die "No keyboard backlight LED found."
            local max
            max=$(sysread "$led/max_brightness")
            [[ "$val" -le "$max" ]] || die "Max level is $max."
            syswrite "$led/brightness" "$val"
            ok "Keyboard backlight set to $val (max $max)"
            ;;

        off)
            need_root
            local led
            led=$(_kb_led)
            [[ -n "$led" ]] || die "No keyboard backlight LED found."
            syswrite "$led/brightness" 0
            ok "Keyboard backlight off"
            ;;

        max)
            need_root
            local led
            led=$(_kb_led)
            [[ -n "$led" ]] || die "No keyboard backlight LED found."
            local max
            max=$(sysread "$led/max_brightness")
            syswrite "$led/brightness" "$max"
            ok "Keyboard backlight at maximum ($max)"
            ;;

        *)
            err "Unknown keyboard subcommand: $sub"
            echo "Usage: huawei keyboard {status|set <level>|off|max}"
            exit 1
            ;;
    esac
}

# =============================================================================
# SLEEP — suspend state management and wake diagnostics
# =============================================================================
cmd_sleep() {
    local sub="${1:-status}"
    shift 2>/dev/null || true

    case "$sub" in
        status)
            hdr "Sleep / Suspend"

            # Current + available mem_sleep states
            if [[ -f /sys/power/mem_sleep ]]; then
                local raw
                raw=$(sysread /sys/power/mem_sleep)
                local current
                current=$(echo "$raw" | grep -oP '\[\K[^\]]+' || echo "unknown")
                local available
                available="${raw//[\[\]]/}"
                echo -e "  Active state : ${BLD}${current}${RST}"
                echo -e "  Available    : $available"
                echo ""
                case "$current" in
                    s2idle)
                        ok "s2idle (S0ix modern standby) — recommended for Meteor Lake"
                        ;;
                    deep)
                        warn "deep (S3) — works but uses more resume time; s2idle preferred on this CPU"
                        ;;
                esac
            else
                warn "/sys/power/mem_sleep not found"
            fi

            # Kernel command line hint
            echo ""
            if grep -q "mem_sleep_default" /proc/cmdline 2>/dev/null; then
                local val
                val=$(grep -oP 'mem_sleep_default=\K\S+' /proc/cmdline)
                ok "mem_sleep_default=$val set in kernel cmdline"
            else
                dim "  mem_sleep_default not set in kernel cmdline"
                dim "  To persist: add mem_sleep_default=s2idle to GRUB_CMDLINE_LINUX in /etc/default/grub"
            fi

            # Last wake source
            echo ""
            info "Last suspend/wake events (journalctl):"
            journalctl -b --no-pager -q \
                -g "Reached target Sleep|Starting Suspend|Finished.*Resume" \
                2>/dev/null | tail -6 | sed 's/^/  /' || dim "  (none found this boot)"
            ;;

        set)
            need_root
            local state="${1:-}"
            [[ -n "$state" ]] || die "Usage: huawei sleep set <s2idle|deep>"
            [[ -f /sys/power/mem_sleep ]] || die "/sys/power/mem_sleep not available"
            local available
            available=$(sysread /sys/power/mem_sleep)
            echo "$available" | grep -qw "$state" || die "State '$state' not available. Options: $available"
            syswrite /sys/power/mem_sleep "$state"
            ok "Sleep state set to: $state  (active until reboot)"
            warn "To persist: add mem_sleep_default=${state} to GRUB_CMDLINE_LINUX in /etc/default/grub, then: sudo update-grub"
            ;;

        persist)
            need_root
            local state="${1:-s2idle}"
            local grub_file="/etc/default/grub"
            [[ -f "$grub_file" ]] || die "GRUB config not found at $grub_file"

            if grep -q "mem_sleep_default=" "$grub_file"; then
                sed -i "s/mem_sleep_default=[^ \"]*/mem_sleep_default=${state}/" "$grub_file"
            else
                sed -i "s/GRUB_CMDLINE_LINUX=\"/GRUB_CMDLINE_LINUX=\"mem_sleep_default=${state} /" "$grub_file"
            fi
            update-grub 2>/dev/null && ok "GRUB updated — mem_sleep_default=${state} will persist after reboot"
            ;;

        diagnose)
            hdr "Sleep Diagnostics"

            info "Wake-up sources:"
            cat /proc/acpi/wakeup 2>/dev/null | grep "enabled" | sed 's/^/  /' \
                || dim "  /proc/acpi/wakeup not available"

            echo ""
            info "Last 10 suspend/resume kernel messages:"
            journalctl -b --no-pager -q -g "PM:|suspend|resume|wake" -n 20 \
                2>/dev/null | tail -10 | sed 's/^/  /' || dim "  (none)"

            echo ""
            info "Last wake reason (dmesg):"
            dmesg 2>/dev/null | grep -iE "wake|resume|PM: " | tail -8 | sed 's/^/  /' \
                || dim "  (none)"
            ;;

        *)
            err "Unknown sleep subcommand: $sub"
            echo "Usage: huawei sleep {status|set <s2idle|deep>|persist [state]|diagnose}"
            exit 1
            ;;
    esac
}

# =============================================================================
# DUAL-BOOT — Windows/Linux coexistence utilities
# =============================================================================
cmd_dualboot() {
    local sub="${1:-status}"
    shift 2>/dev/null || true

    # Find NTFS partitions
    _ntfs_parts() {
        lsblk -rno NAME,FSTYPE,LABEL,SIZE,MOUNTPOINT 2>/dev/null \
            | awk '$2=="ntfs"{print $1,$3,$4,$5}'
    }

    case "$sub" in
        status)
            hdr "Dual-Boot Status"

            # Windows partitions
            echo -e "  ${BLD}NTFS partitions:${RST}"
            local found=false
            while IFS=' ' read -r dev label size mp; do
                printf "  /dev/%-12s  %-20s  %-8s  %s\n" \
                    "$dev" "${label:-(no label)}" "$size" "${mp:-(not mounted)}"
                found=true
            done < <(_ntfs_parts)
            $found || dim "  None found"

            # Hardware clock mode
            echo ""
            echo -e "  ${BLD}Hardware clock:${RST}"
            local rtc_mode
            rtc_mode=$(timedatectl show --property=LocalRTC --value 2>/dev/null || echo "unknown")
            if [[ "$rtc_mode" == "no" ]]; then
                ok "UTC (correct for Linux/Windows dual-boot)"
            elif [[ "$rtc_mode" == "yes" ]]; then
                warn "Local time — clocks will drift between OS reboots"
                dim "  Fix with: huawei dual-boot fix-clock"
            else
                dim "  Unknown RTC mode: $rtc_mode"
            fi

            # Fast startup check
            echo ""
            echo -e "  ${BLD}Windows Fast Startup:${RST}"
            local hiberfil_found=false
            while IFS=' ' read -r dev label size mp; do
                local mnt="/mnt/_huawei_dualboot_check_$$"
                mkdir -p "$mnt"
                if mount -t ntfs3 -o ro "/dev/${dev}" "$mnt" 2>/dev/null \
                   || mount -t ntfs -o ro "/dev/${dev}" "$mnt" 2>/dev/null; then
                    if [[ -f "$mnt/hiberfil.sys" ]]; then
                        local hib_size
                        hib_size=$(du -sh "$mnt/hiberfil.sys" 2>/dev/null | cut -f1)
                        warn "hiberfil.sys found on /dev/${dev} (${hib_size}) — Fast Startup is ON"
                        warn "Mounting this partition read-write risks filesystem corruption"
                        dim "  Fix in Windows: Control Panel → Power → Turn on fast startup → uncheck"
                        hiberfil_found=true
                    fi
                    umount "$mnt" 2>/dev/null || true
                fi
                rmdir "$mnt" 2>/dev/null || true
            done < <(_ntfs_parts)
            $hiberfil_found || ok "No hiberfil.sys found (Fast Startup appears off, or partition not mounted)"
            ;;

        fix-clock)
            need_root
            timedatectl set-local-rtc 0 --adjust-system-clock
            ok "RTC set to UTC — Linux clock corrected"
            info "Windows fix: run in PowerShell as admin:"
            echo -e "  ${DIM}reg add HKLM\\SYSTEM\\CurrentControlSet\\Control\\TimeZoneInformation /v RealTimeIsUniversal /t REG_DWORD /d 1 /f${RST}"
            ;;

        mount)
            need_root
            local dev="${1:-}"
            if [[ -z "$dev" ]]; then
                echo "Available NTFS partitions:"
                _ntfs_parts | awk '{printf "  /dev/%s  %s  %s\n",$1,$2,$3}'
                echo ""
                die "Usage: huawei dual-boot mount <device>  e.g. sda3 or nvme0n1p3"
            fi
            [[ "$dev" != /dev/* ]] && dev="/dev/$dev"
            [[ -b "$dev" ]] || die "Device not found: $dev"

            local label
            label=$(lsblk -no LABEL "$dev" 2>/dev/null | tr -d ' ')
            local mnt="/mnt/${label:-windows}"
            mkdir -p "$mnt"

            # Check for hiberfil.sys first (safe mount)
            local tmp_mnt="/mnt/_huawei_hibcheck_$$"
            mkdir -p "$tmp_mnt"
            if mount -t ntfs3 -o ro "$dev" "$tmp_mnt" 2>/dev/null \
               || mount -t ntfs  -o ro "$dev" "$tmp_mnt" 2>/dev/null; then
                if [[ -f "$tmp_mnt/hiberfil.sys" ]]; then
                    umount "$tmp_mnt"; rmdir "$tmp_mnt"
                    warn "hiberfil.sys present — Windows Fast Startup is on."
                    warn "Mounting read-write may corrupt the filesystem."
                    read -rp "Mount read-only instead? [Y/n]: " ans
                    if [[ "${ans,,}" != "n" ]]; then
                        mount -t ntfs3 -o ro "$dev" "$mnt" 2>/dev/null \
                            || mount -t ntfs -o ro "$dev" "$mnt" \
                            || die "Mount failed"
                        ok "Mounted read-only at $mnt"
                        return
                    fi
                fi
                umount "$tmp_mnt" 2>/dev/null || true
            fi
            rmdir "$tmp_mnt" 2>/dev/null || true

            mount -t ntfs3 "$dev" "$mnt" 2>/dev/null \
                || mount -t ntfs-3g "$dev" "$mnt" 2>/dev/null \
                || mount -t ntfs "$dev" "$mnt" \
                || die "Mount failed — is ntfs3 or ntfs-3g available?"
            ok "Mounted $dev at $mnt"
            ;;

        umount|unmount)
            need_root
            local target="${1:-}"
            [[ -n "$target" ]] || die "Usage: huawei dual-boot umount <mountpoint|device>"
            umount "$target" && ok "Unmounted $target"
            ;;

        *)
            err "Unknown dual-boot subcommand: $sub"
            echo "Usage: huawei dual-boot {status|fix-clock|mount <dev>|umount <target>}"
            exit 1
            ;;
    esac
}

