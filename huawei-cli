#!/usr/bin/env bash
# =============================================================================
# huawei-cli — Hardware management utility for Huawei MateBook on Linux
# Tested on: MateBook X Pro 2024 (VGHH-XX), Ubuntu 24.04, Kernel 6.17
# Usage: huawei <command> [subcommand] [args]
# Install: sudo cp huawei-cli /usr/local/bin/huawei && sudo chmod +x /usr/local/bin/huawei
# =============================================================================

set -euo pipefail

# --- Colours -----------------------------------------------------------------
RED='\033[0;31m'
GRN='\033[0;32m'
YLW='\033[1;33m'
BLU='\033[0;34m'
CYN='\033[0;36m'
MAG='\033[0;35m'
BLD='\033[1m'
DIM='\033[2m'
RST='\033[0m'

# --- Output helpers ----------------------------------------------------------
info()  { echo -e "${BLU}•${RST} $*"; }
ok()    { echo -e "${GRN}✓${RST} $*"; }
warn()  { echo -e "${YLW}!${RST} $*"; }
err()   { echo -e "${RED}✗${RST} $*" >&2; }
dim()   { echo -e "${DIM}$*${RST}"; }
bold()  { echo -e "${BLD}$*${RST}"; }
hdr()   { echo -e "\n${BLD}${CYN}$*${RST}"; }

die() { err "$*"; exit 1; }

need_root() {
    [[ $EUID -eq 0 ]] || die "This command requires root. Run with sudo."
}

# Numeric guard: is $1 a non-negative integer?
is_int() { [[ "$1" =~ ^[0-9]+$ ]]; }

# Read a sysfs file, return empty string on failure
sysread() { cat "$1" 2>/dev/null || true; }

# Write to sysfs, die on failure
syswrite() {
    local path="$1" val="$2"
    echo "$val" > "$path" 2>/dev/null || die "Cannot write '$val' to $path"
}

# =============================================================================
# STATUS — full hardware report
# =============================================================================
cmd_status() {
    local pad=32

    _row() {
        local label="$1" state="$2" note="${3:-}"
        local sym col
        case "$state" in
            OK)      sym="✓"; col="$GRN" ;;
            WARN)    sym="!"; col="$YLW" ;;
            FAIL)    sym="✗"; col="$RED" ;;
            *)       sym="?"; col="$CYN" ;;
        esac
        printf "  %-${pad}s %b%s %-6s%b %s\n" \
            "$label" "$col" "$sym" "[$state]" "$RST" "$note"
    }

    local model kernel
    model=$(sudo dmidecode -s system-product-name 2>/dev/null \
        || dmidecode -s system-product-name 2>/dev/null \
        || echo "unknown (run as root for model)")
    kernel=$(uname -r)

    echo ""
    echo -e "${BLD}${CYN}╔══════════════════════════════════════════╗${RST}"
    echo -e "${BLD}${CYN}║       Huawei MateBook Hardware Status    ║${RST}"
    echo -e "${BLD}${CYN}╚══════════════════════════════════════════╝${RST}"
    echo -e "  Model  : ${BLD}${model}${RST}"
    echo -e "  Kernel : ${BLD}${kernel}${RST}"
    echo ""

    hdr "Input"
    if grep -qi "GXTP7863" /proc/bus/input/devices 2>/dev/null; then
        _row "Touchpad (GXTP7863)" "OK" "Detected"
    else
        _row "Touchpad (GXTP7863)" "FAIL" "Not detected — try: huawei touchpad rebind"
    fi
    if systemctl is-enabled touchpad-rebind.service &>/dev/null; then
        _row "Touchpad rebind service" "OK" "Enabled at boot"
    else
        _row "Touchpad rebind service" "WARN" "Not enabled — run setup script"
    fi

    hdr "Power"
    local bat_path
    bat_path=$(ls -d /sys/class/power_supply/BAT* 2>/dev/null | head -1 || true)
    if [[ -n "$bat_path" ]]; then
        local pct status thresh
        pct=$(sysread "$bat_path/capacity")
        status=$(sysread "$bat_path/status")
        thresh=$(sysread "$bat_path/charge_control_end_threshold")
        local note="${pct}%  ${status}"
        [[ -n "$thresh" ]] && note+="  (threshold: ${thresh}%)"
        _row "Battery" "OK" "$note"
    else
        _row "Battery" "UNKNOWN" "No battery found"
    fi

    if command -v powerprofilesctl &>/dev/null; then
        local profile
        profile=$(powerprofilesctl get 2>/dev/null || echo "unknown")
        _row "Power profile" "OK" "$profile"
    elif [[ -f /sys/firmware/acpi/platform_profile ]]; then
        local profile
        profile=$(sysread /sys/firmware/acpi/platform_profile)
        _row "Power profile (ACPI)" "OK" "$profile"
    else
        _row "Power profile" "UNKNOWN" "power-profiles-daemon not found"
    fi

    hdr "Display"
    local bl_path
    bl_path=$(ls -d /sys/class/backlight/*/brightness 2>/dev/null | head -1 || true)
    if [[ -n "$bl_path" ]]; then
        local cur max pct_bl
        cur=$(sysread "$bl_path")
        max=$(sysread "${bl_path%brightness}max_brightness")
        if [[ -n "$cur" && -n "$max" && "$max" -gt 0 ]]; then
            pct_bl=$(( cur * 100 / max ))
            _row "Backlight" "OK" "${pct_bl}%  (${cur}/${max})"
        else
            _row "Backlight" "OK" "Path found: $bl_path"
        fi
    else
        _row "Backlight" "UNKNOWN" "No backlight sysfs path"
    fi

    local kb_path
    kb_path=$(ls -d /sys/class/leds/*/brightness 2>/dev/null | grep -i "kbd\|keyboard\|backlight" | head -1 || true)
    if [[ -n "$kb_path" ]]; then
        local kb_val
        kb_val=$(sysread "$kb_path")
        _row "Keyboard backlight" "OK" "Level: $kb_val"
    else
        _row "Keyboard backlight" "UNKNOWN" "No LED sysfs entry found"
    fi

    hdr "Network"
    if rfkill list wifi 2>/dev/null | grep -q "Soft blocked: no"; then
        local ssid
        ssid=$(iwgetid -r 2>/dev/null || echo "not associated")
        _row "WiFi (Intel CNVi)" "OK" "$ssid"
    elif rfkill list wifi 2>/dev/null | grep -q "Soft blocked: yes"; then
        _row "WiFi (Intel CNVi)" "WARN" "Soft-blocked (rfkill)"
    else
        _row "WiFi (Intel CNVi)" "UNKNOWN" "Check rfkill list"
    fi

    if rfkill list bluetooth 2>/dev/null | grep -q "Soft blocked: no"; then
        _row "Bluetooth" "OK" "Enabled"
    else
        _row "Bluetooth" "WARN" "Disabled or blocked"
    fi

    hdr "Audio"
    if systemctl --user is-active pipewire &>/dev/null 2>&1; then
        local vol
        vol=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null | awk '{print $2}' || echo "?")
        _row "PipeWire" "OK" "Running  volume: ${vol}"
    else
        _row "PipeWire" "WARN" "Not active for current user"
    fi

    hdr "Camera"
    if lsmod | grep -q "intel_ipu6"; then
        _row "IPU6 kernel module" "OK" "intel_ipu6 loaded"
    else
        _row "IPU6 kernel module" "FAIL" "Not loaded"
    fi
    if [[ -f /usr/lib/libcamhal/plugins/ipu6epmtl.so ]]; then
        _row "Camera HAL (ipu6epmtl)" "OK" "Plugin installed"
    else
        _row "Camera HAL (ipu6epmtl)" "FAIL" "Not installed — run setup script"
    fi
    if dmesg 2>/dev/null | grep -q "INT3472.*EBUSY"; then
        _row "Camera streaming" "FAIL" "INT3472 GPIO conflict (upstream bug)"
    else
        _row "Camera streaming" "UNKNOWN" "Run: huawei camera test"
    fi

    _row "Fingerprint reader" "FAIL" "No Linux driver (Goodix — unsupported)"

    echo ""
}

# =============================================================================
# BATTERY
# =============================================================================
_bat_path() {
    ls -d /sys/class/power_supply/BAT* 2>/dev/null | head -1 || true
}

cmd_battery() {
    local sub="${1:-status}"
    shift 2>/dev/null || true

    case "$sub" in
        status)
            local bat
            bat=$(_bat_path)
            [[ -n "$bat" ]] || die "No battery found."

            hdr "Battery"
            local pct status health thresh_end thresh_start
            pct=$(sysread "$bat/capacity")
            status=$(sysread "$bat/status")
            health=$(sysread "$bat/health" || echo "unknown")
            thresh_end=$(sysread "$bat/charge_control_end_threshold" || true)
            thresh_start=$(sysread "$bat/charge_control_start_threshold" || true)

            echo -e "  Charge   : ${BLD}${pct}%${RST}"
            echo -e "  Status   : $status"
            echo -e "  Health   : $health"
            [[ -n "$thresh_end"   ]] && echo -e "  Threshold: stop at ${thresh_end}%  start at ${thresh_start:-(auto)}%"

            if command -v upower &>/dev/null; then
                local udev
                udev=$(upower -e 2>/dev/null | grep battery | head -1 || true)
                if [[ -n "$udev" ]]; then
                    echo ""
                    upower -i "$udev" 2>/dev/null | grep -E "energy|time to|voltage|temperature" \
                        | sed 's/^/  /'
                fi
            fi
            ;;

        threshold)
            need_root
            local val="${1:-}"
            local bat
            bat=$(_bat_path)
            [[ -n "$bat" ]] || die "No battery found."

            local thresh_path="$bat/charge_control_end_threshold"
            [[ -f "$thresh_path" ]] || die "Charge threshold not supported on this kernel/driver."

            if [[ -z "$val" ]]; then
                local cur
                cur=$(sysread "$thresh_path")
                echo "Current charge threshold: ${cur}%"
                echo "Usage: huawei battery threshold <50-100>"
                return
            fi

            is_int "$val" || die "Threshold must be an integer (50–100)."
            [[ "$val" -ge 50 && "$val" -le 100 ]] || die "Threshold must be between 50 and 100."

            syswrite "$thresh_path" "$val"
            ok "Charge threshold set to ${val}%"
            warn "This setting resets on reboot. To persist it, run: huawei battery threshold-persist $val"
            ;;

        threshold-persist)
            need_root
            local val="${1:-}"
            is_int "$val" || die "Usage: huawei battery threshold-persist <50-100>"
            [[ "$val" -ge 50 && "$val" -le 100 ]] || die "Threshold must be between 50 and 100."

            local bat
            bat=$(_bat_path)
            local bat_name
            bat_name=$(basename "$bat")
            local svc_file="/etc/systemd/system/huawei-battery-threshold.service"

            cat > "$svc_file" << EOF
[Unit]
Description=Huawei MateBook battery charge threshold
After=multi-user.target

[Service]
Type=oneshot
ExecStart=/bin/bash -c 'echo ${val} > /sys/class/power_supply/${bat_name}/charge_control_end_threshold'
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
EOF
            systemctl daemon-reload
            systemctl enable --now huawei-battery-threshold.service
            ok "Threshold ${val}% persisted via systemd service"
            ;;

        *)
            err "Unknown battery subcommand: $sub"
            echo "Usage: huawei battery {status|threshold [val]|threshold-persist <val>}"
            exit 1
            ;;
    esac
}

# =============================================================================
# POWER PROFILES
# =============================================================================
cmd_power() {
    local sub="${1:-status}"
    shift 2>/dev/null || true

    # Prefer power-profiles-daemon; fall back to ACPI platform profile
    _get_profile() {
        if command -v powerprofilesctl &>/dev/null; then
            powerprofilesctl get 2>/dev/null
        elif [[ -f /sys/firmware/acpi/platform_profile ]]; then
            sysread /sys/firmware/acpi/platform_profile
        else
            echo "unavailable"
        fi
    }

    _set_profile() {
        local p="$1"
        if command -v powerprofilesctl &>/dev/null; then
            powerprofilesctl set "$p" && ok "Profile set to: $p"
        elif [[ -f /sys/firmware/acpi/platform_profile ]]; then
            need_root
            syswrite /sys/firmware/acpi/platform_profile "$p"
            ok "ACPI platform profile set to: $p"
        else
            die "No power profile mechanism found (install power-profiles-daemon)."
        fi
    }

    case "$sub" in
        status)
            local cur avail
            cur=$(_get_profile)
            echo -e "  Current profile: ${BLD}${cur}${RST}"
            if command -v powerprofilesctl &>/dev/null; then
                echo ""
                echo "  Available profiles:"
                powerprofilesctl list 2>/dev/null | grep ":" | sed 's/^/    /'
            elif [[ -f /sys/firmware/acpi/platform_profile_choices ]]; then
                avail=$(sysread /sys/firmware/acpi/platform_profile_choices)
                echo "  Available: $avail"
            fi
            ;;
        set)
            local profile="${1:-}"
            [[ -n "$profile" ]] || die "Usage: huawei power set <balanced|performance|power-saver>"
            _set_profile "$profile"
            ;;
        balanced)     _set_profile "balanced" ;;
        performance)  _set_profile "performance" ;;
        saver|powersave|power-saver) _set_profile "power-saver" ;;
        *)
            err "Unknown power subcommand: $sub"
            echo "Usage: huawei power {status|set <profile>|balanced|performance|saver}"
            exit 1
            ;;
    esac
}

# =============================================================================
# TOUCHPAD
# =============================================================================
cmd_touchpad() {
    local sub="${1:-status}"
    shift 2>/dev/null || true

    case "$sub" in
        status)
            hdr "Touchpad"
            if grep -qi "GXTP7863" /proc/bus/input/devices 2>/dev/null; then
                ok "GXTP7863 detected in /proc/bus/input"
            else
                err "GXTP7863 not detected"
            fi

            local quirk="/etc/libinput/local-overrides.quirks"
            if grep -q "GXTP7863" "$quirk" 2>/dev/null; then
                ok "libinput quirk present at $quirk"
            else
                warn "libinput quirk missing — run setup script"
            fi

            if systemctl is-enabled touchpad-rebind.service &>/dev/null; then
                ok "touchpad-rebind.service enabled at boot"
            else
                warn "touchpad-rebind.service not enabled"
            fi
            ;;

        rebind)
            need_root
            info "Unbinding GXTP7863 from i2c_hid_acpi..."
            echo "i2c-GXTP7863:00" > /sys/bus/i2c/drivers/i2c_hid_acpi/unbind 2>/dev/null \
                || warn "Unbind returned non-zero (device may already be unbound)"
            sleep 1
            info "Rebinding..."
            echo "i2c-GXTP7863:00" > /sys/bus/i2c/drivers/i2c_hid_acpi/bind 2>/dev/null \
                && ok "Touchpad rebound successfully" \
                || warn "Rebind failed — reboot may be required"
            ;;

        *)
            err "Unknown touchpad subcommand: $sub"
            echo "Usage: huawei touchpad {status|rebind}"
            exit 1
            ;;
    esac
}

# =============================================================================
# DISPLAY
# =============================================================================
cmd_display() {
    local sub="${1:-status}"
    shift 2>/dev/null || true

    _bl_path() {
        ls -d /sys/class/backlight/*/brightness 2>/dev/null | head -1 || true
    }

    _bl_max() {
        local p
        p=$(_bl_path)
        [[ -n "$p" ]] && sysread "${p%brightness}max_brightness" || echo "0"
    }

    case "$sub" in
        status|brightness)
            local bl
            bl=$(_bl_path)
            if [[ -z "$bl" ]]; then
                warn "No backlight sysfs path found."
                return
            fi
            local cur max pct
            cur=$(sysread "$bl")
            max=$(sysread "${bl%brightness}max_brightness")
            pct=$(( cur * 100 / max ))

            if [[ "${sub}" == "status" ]]; then
                hdr "Display"
            fi

            if [[ -z "${1:-}" ]]; then
                echo -e "  Brightness: ${BLD}${pct}%${RST}  (raw ${cur} / ${max})"
                echo "  Usage: huawei display brightness <0-100>"
                return
            fi

            need_root
            local val="$1"
            is_int "$val" || die "Brightness must be 0–100."
            [[ "$val" -le 100 ]] || die "Brightness must be 0–100."
            local raw=$(( val * max / 100 ))
            syswrite "$bl" "$raw"
            ok "Brightness set to ${val}%  (raw $raw)"
            ;;

        *)
            err "Unknown display subcommand: $sub"
            echo "Usage: huawei display {status|brightness [0-100]}"
            exit 1
            ;;
    esac
}

# =============================================================================
# AUDIO
# =============================================================================
cmd_audio() {
    local sub="${1:-status}"
    shift 2>/dev/null || true

    _need_wpctl() {
        command -v wpctl &>/dev/null || die "wpctl not found — is pipewire-utils installed?"
    }

    case "$sub" in
        status)
            _need_wpctl
            hdr "Audio (PipeWire)"
            if systemctl --user is-active pipewire &>/dev/null 2>&1; then
                ok "PipeWire running"
            else
                warn "PipeWire not active for current user"
            fi
            echo ""
            wpctl status 2>/dev/null | grep -A30 "Audio" | head -35
            ;;

        volume)
            _need_wpctl
            if [[ -z "${1:-}" ]]; then
                wpctl get-volume @DEFAULT_AUDIO_SINK@
                echo "Usage: huawei audio volume <0-100>|mute|unmute"
                return
            fi
            case "$1" in
                mute)   wpctl set-mute @DEFAULT_AUDIO_SINK@ 1 && ok "Muted" ;;
                unmute) wpctl set-mute @DEFAULT_AUDIO_SINK@ 0 && ok "Unmuted" ;;
                toggle-mute) wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle && ok "Toggled mute" ;;
                *)
                    is_int "$1" || die "Volume must be 0–100, mute, or unmute."
                    [[ "$1" -le 100 ]] || die "Volume must be 0–100."
                    wpctl set-volume @DEFAULT_AUDIO_SINK@ "${1}%"
                    ok "Volume set to ${1}%"
                    ;;
            esac
            ;;

        mute)         wpctl set-mute @DEFAULT_AUDIO_SINK@ 1 && ok "Muted" ;;
        unmute)       wpctl set-mute @DEFAULT_AUDIO_SINK@ 0 && ok "Unmuted" ;;

        restart)
            systemctl --user restart pipewire pipewire-pulse wireplumber 2>/dev/null && \
                ok "PipeWire restarted" || warn "Restart had errors — check: systemctl --user status pipewire"
            ;;

        *)
            err "Unknown audio subcommand: $sub"
            echo "Usage: huawei audio {status|volume [0-100|mute|unmute]|mute|unmute|restart}"
            exit 1
            ;;
    esac
}

# =============================================================================
# WIFI
# =============================================================================
cmd_wifi() {
    local sub="${1:-status}"
    shift 2>/dev/null || true

    case "$sub" in
        status)
            hdr "WiFi"
            rfkill list wifi 2>/dev/null || echo "  rfkill: no wifi entry"
            local ssid
            ssid=$(iwgetid -r 2>/dev/null || echo "(not connected)")
            echo -e "  SSID: ${BLD}${ssid}${RST}"
            ;;
        enable|on)
            need_root
            rfkill unblock wifi && ok "WiFi enabled"
            ;;
        disable|off)
            need_root
            rfkill block wifi && ok "WiFi disabled"
            ;;
        toggle)
            need_root
            if rfkill list wifi | grep -q "Soft blocked: no"; then
                rfkill block wifi && ok "WiFi disabled"
            else
                rfkill unblock wifi && ok "WiFi enabled"
            fi
            ;;
        *)
            err "Unknown wifi subcommand: $sub"
            echo "Usage: huawei wifi {status|enable|disable|toggle}"
            exit 1
            ;;
    esac
}

