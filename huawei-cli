# =============================================================================
# CAMERA
# =============================================================================
cmd_camera() {
    local sub="${1:-status}"
    shift 2>/dev/null || true

    case "$sub" in
        status)
            hdr "Camera"
            if lsmod | grep -q "intel_ipu6"; then
                ok "intel_ipu6 module loaded"
            else
                err "intel_ipu6 not loaded"
            fi
            if [[ -f /usr/lib/libcamhal/plugins/ipu6epmtl.so ]]; then
                ok "Camera HAL plugin installed"
            else
                err "Camera HAL plugin missing"
            fi
            if dmesg 2>/dev/null | grep -q "INT3472.*EBUSY"; then
                warn "INT3472 GPIO conflict detected in dmesg — streaming blocked (upstream bug)"
                dim "  Track: https://github.com/intel/ipu6-drivers/issues/399"
            else
                info "No INT3472 error in dmesg (camera may be functional)"
            fi
            echo ""
            info "V4L2 devices:"
            ls /dev/video* 2>/dev/null | sed 's/^/  /' || echo "  None found"
            ;;

        test)
            info "Testing camera pipeline via GStreamer (Ctrl+C to stop)..."
            warn "This will fail on VGHH-XX while INT3472 bug is unresolved."
            sudo -E gst-launch-1.0 icamerasrc ! fakesink 2>&1 | head -20
            ;;

        dmesg)
            info "Camera-related kernel messages:"
            dmesg 2>/dev/null | grep -iE "ipu6|INT3472|OV13B10|OV01A1S|icamera" | tail -30 | sed 's/^/  /'
            ;;

        *)
            err "Unknown camera subcommand: $sub"
            echo "Usage: huawei camera {status|test|dmesg}"
            exit 1
            ;;
    esac
}

# =============================================================================
# UPDATES — track known upstream issues and local fix status
# =============================================================================

# Cache TTL in seconds (default 6 hours; override with HUAWEI_CACHE_TTL)
_CACHE_TTL="${HUAWEI_CACHE_TTL:-21600}"
_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/huawei-cli"
_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/huawei-cli"
_USER_ISSUES_FILE="$_CONFIG_DIR/tracked-issues"

# Built-in tracked items — format: "type:ref|label"
#   type github  → ref = owner/repo/number
#   type kernel  → ref = minimum kernel version where fix landed
#   type package → ref = package name to check for updates
#   type local   → ref = script function name
_BUILTIN_ITEMS=(
    "github:intel/ipu6-drivers/399|Camera: INT3472 GPIO conflict (VGHH-XX webcam blocked)"
    "local:_check_fingerprint|Fingerprint: Goodix sensor Linux driver support"
    "kernel:6.12|Kernel: minimum recommended for touchpad regression fix"
    "package:linux-image-generic-hwe-24.04|Kernel: HWE track updates available"
    "package:libcamhal-ipu6epmtl|Camera HAL: ipu6epmtl updates available"
)

# --- Cache helpers -----------------------------------------------------------
_cache_key()  { echo "${1//\//_}" | tr ':' '_'; }

_cache_read() {
    local key
    key=$(_cache_key "$1")
    local f="$_CACHE_DIR/${key}.json" ts="$_CACHE_DIR/${key}.ts"
    [[ -f "$f" && -f "$ts" ]] || return 1
    local age=$(( $(date +%s) - $(cat "$ts") ))
    [[ "$age" -lt "$_CACHE_TTL" ]] || return 1
    cat "$f"
}

_cache_write() {
    local key data
    key=$(_cache_key "$1"); data="$2"
    mkdir -p "$_CACHE_DIR"
    echo "$data" > "$_CACHE_DIR/${key}.json"
    date +%s      > "$_CACHE_DIR/${key}.ts"
}

# --- JSON field extractor (python3 — no jq dependency) ----------------------
_jq() {
    local field="$1"
    python3 -c "
import json,sys
try:
    d=json.load(sys.stdin)
    v=d.get('$field','')
    print(v if v is not None else '')
except Exception:
    print('')
"
}

# --- GitHub issue fetch ------------------------------------------------------
# Returns: "STATE|TITLE|UPDATED_AT|COMMENTS|HTML_URL"
_gh_issue() {
    local owner="$1" repo="$2" number="$3"
    local ref="$owner/$repo/$number"

    local json
    if ! json=$(_cache_read "$ref"); then
        json=$(curl -sf --max-time 10 \
            -H "Accept: application/vnd.github.v3+json" \
            -H "User-Agent: huawei-cli/1.0" \
            "https://api.github.com/repos/${owner}/${repo}/issues/${number}") \
            || { echo "FETCH_ERROR|||"; return 1; }
        _cache_write "$ref" "$json"
    fi

    local state title updated comments url
    state=$(   echo "$json" | _jq state)
    title=$(   echo "$json" | _jq title)
    updated=$( echo "$json" | _jq updated_at)
    comments=$(echo "$json" | _jq comments)
    url=$(     echo "$json" | _jq html_url)

    echo "${state}|${title}|${updated}|${comments}|${url}"
}

# --- Render a single issue row -----------------------------------------------
_show_gh_item() {
    local ref="$1" label="$2"
    local owner repo number
    IFS='/' read -r owner repo number <<< "$ref"

    echo -e "\n  ${BLD}${label}${RST}"
    dim "  github.com/${owner}/${repo}/issues/${number}"

    local result
    if ! result=$(_gh_issue "$owner" "$repo" "$number"); then
        warn "  Could not fetch — check your internet connection"
        return
    fi

    local state title updated comments url
    IFS='|' read -r state title updated comments url <<< "$result"

    local state_col state_sym
    case "$state" in
        closed) state_col="$GRN"; state_sym="✓ closed" ;;
        open)   state_col="$RED"; state_sym="● open"   ;;
        *)      state_col="$CYN"; state_sym="? $state"  ;;
    esac

    echo -e "  Status  : ${state_col}${BLD}${state_sym}${RST}"
    [[ -n "$title"    ]] && echo -e "  Title   : $title"
    [[ -n "$updated"  ]] && echo -e "  Updated : ${updated%T*}"
    [[ -n "$comments" ]] && echo -e "  Comments: $comments"
    [[ -n "$url"      ]] && dim "  $url"
}

# --- Local checks ------------------------------------------------------------
_check_fingerprint() {
    echo -e "\n  ${BLD}Fingerprint: Goodix sensor Linux driver support${RST}"

    # Find fingerprint USB device (Goodix VID = 27c6, common MateBook PIDs)
    local fp_usb
    fp_usb=$(lsusb 2>/dev/null | grep -i "27c6" || true)

    if [[ -z "$fp_usb" ]]; then
        dim "  No Goodix USB fingerprint device found on USB bus"
        return
    fi

    echo -e "  Device  : $fp_usb"

    # Extract VID:PID for libfprint check
    local vidpid
    vidpid=$(echo "$fp_usb" | grep -oP '27c6:[0-9a-fA-F]{4}' | head -1)

    # Check if fprintd sees any enrolled/available devices
    if command -v fprintd-list &>/dev/null; then
        local fp_out
        fp_out=$(fprintd-list "$USER" 2>&1 || true)
        if echo "$fp_out" | grep -qi "no devices"; then
            echo -e "  Status  : ${RED}${BLD}● not supported${RST}  (fprintd: no devices)"
        elif echo "$fp_out" | grep -qi "error\|no enrolled"; then
            echo -e "  Status  : ${YLW}${BLD}! driver present but no enrolled fingers${RST}"
        else
            echo -e "  Status  : ${GRN}${BLD}✓ may be working — check fprintd-list${RST}"
        fi
    else
        echo -e "  Status  : ${YLW}! fprintd not installed — cannot check${RST}"
    fi

    # Check libfprint supported device list
    local fp_lib
    fp_lib=$(find /usr/lib -name "libfprint*.so*" 2>/dev/null | head -1)
    if [[ -n "$vidpid" && -n "$fp_lib" ]]; then
        if strings "$fp_lib" 2>/dev/null | grep -qi "${vidpid,,}"; then
            ok "  $vidpid found in libfprint device strings"
        else
            warn "  $vidpid not found in libfprint — driver likely missing"
        fi
    fi

    dim "  libfprint issues: https://gitlab.freedesktop.org/libfprint/libfprint/-/issues"
}

# --- Kernel version check ----------------------------------------------------
_show_kernel_item() {
    local min_ver="$1" label="$2"
    echo -e "\n  ${BLD}${label}${RST}"
    local running
    running=$(uname -r | grep -oP '^\d+\.\d+')
    local min_major min_minor run_major run_minor
    IFS='.' read -r min_major min_minor <<< "$min_ver"
    IFS='.' read -r run_major run_minor <<< "$running"

    echo -e "  Running : $running  (minimum: $min_ver)"

    if [[ "$run_major" -gt "$min_major" ]] || \
       { [[ "$run_major" -eq "$min_major" ]] && [[ "$run_minor" -ge "$min_minor" ]]; }; then
        ok "  Kernel meets minimum requirement"
    else
        warn "  Kernel ${running} is below minimum ${min_ver} — consider upgrading"
    fi
}

# --- Package update check ----------------------------------------------------
_show_package_item() {
    local pkg="$1" label="$2"
    echo -e "\n  ${BLD}${label}${RST}"

    if ! dpkg -l "$pkg" &>/dev/null; then
        warn "  $pkg is not installed"
        return
    fi

    local installed available
    installed=$(dpkg -l "$pkg" 2>/dev/null | awk '/^ii/{print $3}')
    echo -e "  Installed: $installed"

    # Check apt cache for newer version (no network hit if cache is stale)
    available=$(apt-cache policy "$pkg" 2>/dev/null \
        | awk '/Candidate:/{print $2}')

    if [[ -n "$available" && "$available" != "$installed" ]]; then
        echo -e "  Available: ${YLW}${BLD}$available${RST}  ← update available"
        dim "  Run: sudo apt install $pkg"
    else
        ok "  Up to date${available:+  ($available)}"
    fi
}

# --- Load user-defined issues ------------------------------------------------
_user_items() {
    [[ -f "$_USER_ISSUES_FILE" ]] || return 0
    grep -v '^\s*#' "$_USER_ISSUES_FILE" | grep -v '^\s*$' || true
}

# --- Parse a GitHub URL into owner/repo/number -------------------------------
_parse_gh_url() {
    local url="$1"
    # Accept:  https://github.com/owner/repo/issues/123
    #          github.com/owner/repo/issues/123
    #          owner/repo#123  or  owner/repo/123
    url="${url#https://github.com/}"
    url="${url#github.com/}"
    # owner/repo/issues/N or owner/repo#N
    if [[ "$url" =~ ^([^/]+)/([^/]+)/issues/([0-9]+) ]]; then
        echo "${BASH_REMATCH[1]}/${BASH_REMATCH[2]}/${BASH_REMATCH[3]}"
    elif [[ "$url" =~ ^([^/]+)/([^#]+)#([0-9]+) ]]; then
        echo "${BASH_REMATCH[1]}/${BASH_REMATCH[2]}/${BASH_REMATCH[3]}"
    else
        echo ""
    fi
}

# --- Main updates command ----------------------------------------------------
cmd_updates() {
    local sub="${1:-check}"
    shift 2>/dev/null || true

    case "$sub" in
        check|c)
            local no_cache=false
            [[ "${1:-}" == "--no-cache" || "${1:-}" == "-f" ]] && no_cache=true

            if $no_cache; then
                rm -rf "$_CACHE_DIR"
                info "Cache cleared — fetching fresh data..."
            fi

            hdr "Upstream Issue Tracker"
            local user_count=0
            [[ -f "$_USER_ISSUES_FILE" ]] && user_count=$(grep -c '.' "$_USER_ISSUES_FILE" 2>/dev/null || echo 0)
            echo -e "  ${DIM}Checking ${#_BUILTIN_ITEMS[@]} built-in items + ${user_count} user items${RST}"
            echo -e "  ${DIM}Cache TTL: $(( _CACHE_TTL / 3600 ))h  |  Clear with: huawei updates check --no-cache${RST}"

            # Built-in items
            for item in "${_BUILTIN_ITEMS[@]}"; do
                local type_ref label
                IFS='|' read -r type_ref label <<< "$item"
                local itype iref
                IFS=':' read -r itype iref <<< "$type_ref"

                case "$itype" in
                    github)  _show_gh_item "$iref" "$label" ;;
                    kernel)  _show_kernel_item "$iref" "$label" ;;
                    package) _show_package_item "$iref" "$label" ;;
                    local)   "$iref" ;;
                esac
            done

            # User-defined items
            local user_items
            mapfile -t user_items < <(_user_items)
            for line in "${user_items[@]}"; do
                local ref label
                IFS='|' read -r ref label <<< "$line"
                label="${label:-$ref}"
                local parsed
                parsed=$(_parse_gh_url "$ref")
                if [[ -n "$parsed" ]]; then
                    _show_gh_item "$parsed" "$label"
                else
                    warn "Cannot parse issue ref: $ref"
                fi
            done

            echo ""
            ;;

        add)
            local url="${1:-}"
            [[ -n "$url" ]] || die "Usage: huawei updates add <github-issue-url> [label]"
            local label="${2:-}"

            local parsed
            parsed=$(_parse_gh_url "$url")
            [[ -n "$parsed" ]] || die "Could not parse GitHub issue URL: $url"

            mkdir -p "$_CONFIG_DIR"
            local line="${url}"
            [[ -n "$label" ]] && line="${url}|${label}"
            echo "$line" >> "$_USER_ISSUES_FILE"
            ok "Added: $line"
            dim "  Stored in $_USER_ISSUES_FILE"
            ;;

        remove|rm)
            local url="${1:-}"
            [[ -n "$url" ]] || die "Usage: huawei updates remove <github-issue-url>"
            [[ -f "$_USER_ISSUES_FILE" ]] || die "No user issues file found."
            local escaped="${url//\//\\/}"
            sed -i "/^${escaped}/d" "$_USER_ISSUES_FILE"
            ok "Removed entries matching: $url"
            ;;

        list|ls)
            hdr "Tracked Issues"
            echo -e "  ${BLD}Built-in:${RST}"
            for item in "${_BUILTIN_ITEMS[@]}"; do
                local type_ref label
                IFS='|' read -r type_ref label <<< "$item"
                echo -e "    ${DIM}${type_ref}${RST}  $label"
            done
            echo -e "\n  ${BLD}User-defined${RST}  (${_USER_ISSUES_FILE}):"
            if [[ -f "$_USER_ISSUES_FILE" ]] && [[ -s "$_USER_ISSUES_FILE" ]]; then
                grep -v '^\s*#' "$_USER_ISSUES_FILE" | sed 's/^/    /'
            else
                dim "    (none — use: huawei updates add <github-url>)"
            fi
            echo ""
            ;;

        cache)
            local action="${1:-status}"
            case "$action" in
                clear) rm -rf "$_CACHE_DIR" && ok "Cache cleared" ;;
                status)
                    if [[ -d "$_CACHE_DIR" ]]; then
                        local count
                        count=$(ls "$_CACHE_DIR"/*.json 2>/dev/null | wc -l)
                        echo -e "  Cache dir  : $_CACHE_DIR"
                        echo -e "  Entries    : $count"
                        echo -e "  TTL        : $(( _CACHE_TTL / 3600 ))h  (override: HUAWEI_CACHE_TTL)"
                    else
                        dim "  No cache yet."
                    fi
                    ;;
            esac
            ;;

        *)
            err "Unknown updates subcommand: $sub"
            echo "Usage: huawei updates {check [--no-cache]|add <url> [label]|remove <url>|list|cache}"
            exit 1
            ;;
    esac
}

# =============================================================================
# INFO — system & model details
# =============================================================================
cmd_info() {
    hdr "System Information"
    echo -e "  Model    : ${BLD}$(dmidecode -s system-product-name 2>/dev/null || echo unknown)${RST}"
    echo -e "  BIOS     : $(dmidecode -s bios-version 2>/dev/null || echo unknown)"
    echo -e "  Kernel   : $(uname -r)"
    echo -e "  CPU      : $(grep 'model name' /proc/cpuinfo | head -1 | cut -d: -f2 | xargs)"
    echo -e "  Memory   : $(free -h | awk '/^Mem:/{print $2}') RAM"
    echo -e "  Uptime   : $(uptime -p)"

    hdr "Kernel Modules"
    local mods=(intel_ipu6 i2c_hid_acpi xe i915 snd_hda_intel btintel iwlwifi)
    for m in "${mods[@]}"; do
        if lsmod | grep -q "^${m}"; then
            ok "$m"
        else
            dim "  - $m (not loaded)"
        fi
    done

    hdr "PCI Devices (relevant)"
    lspci 2>/dev/null | grep -iE "display|audio|wireless|bluetooth|camera|thunderbolt" \
        | sed 's/^/  /' || echo "  lspci not available"
}

# =============================================================================
# HELP
# =============================================================================
cmd_help() {
    echo ""
    bold "  huawei — Huawei MateBook hardware CLI"
    dim   "  MateBook X Pro 2024 · Ubuntu 24.04 · Kernel 6.x"
    echo ""
    echo -e "  ${BLD}Usage:${RST} huawei <command> [subcommand] [args]"
    echo ""
    echo -e "  ${BLD}Commands:${RST}"
    echo -e "    ${CYN}status${RST}                         Full hardware status report"
    echo -e "    ${CYN}battery${RST} status                 Battery charge and health"
    echo -e "    ${CYN}battery${RST} threshold [50-100]     Get/set charge stop threshold"
    echo -e "    ${CYN}battery${RST} threshold-persist <n>  Persist threshold via systemd"
    echo -e "    ${CYN}power${RST}   status                 Current power profile"
    echo -e "    ${CYN}power${RST}   set <profile>          Set balanced|performance|power-saver"
    echo -e "    ${CYN}touchpad${RST} status                Touchpad detection and quirks"
    echo -e "    ${CYN}touchpad${RST} rebind                Force i2c rebind (fixes freezes)"
    echo -e "    ${CYN}display${RST} brightness [0-100]     Get/set screen brightness"
    echo -e "    ${CYN}audio${RST}   status                 PipeWire status"
    echo -e "    ${CYN}audio${RST}   volume [0-100|mute]    Get/set volume"
    echo -e "    ${CYN}audio${RST}   restart                Restart PipeWire stack"
    echo -e "    ${CYN}wifi${RST}    status/enable/disable/toggle"
    echo -e "    ${CYN}bluetooth${RST} status/enable/disable/toggle"
    echo -e "    ${CYN}camera${RST}  status                 Camera module/HAL status"
    echo -e "    ${CYN}camera${RST}  test                   Run GStreamer test pipeline"
    echo -e "    ${CYN}camera${RST}  dmesg                  Camera kernel log messages"
    echo -e "    ${CYN}info${RST}                           System + module info"
    echo -e "    ${CYN}updates${RST} check                  Check status of known upstream issues"
    echo -e "    ${CYN}updates${RST} check --no-cache        Force fresh fetch"
    echo -e "    ${CYN}updates${RST} add <github-url>        Track a custom GitHub issue"
