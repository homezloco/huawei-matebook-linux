# =============================================================================
# Main dispatcher
# =============================================================================
main() {
    local cmd="${1:-help}"
    shift 2>/dev/null || true

    case "$cmd" in
        status|s)               cmd_status "$@" ;;
        battery|bat|b)          cmd_battery "$@" ;;
        power|pwr|p)            cmd_power "$@" ;;
        touchpad|tp)            cmd_touchpad "$@" ;;
        display|disp|screen)    cmd_display "$@" ;;
        audio|sound|a)          cmd_audio "$@" ;;
        wifi|wlan|w)            cmd_wifi "$@" ;;
        bluetooth|bt)           cmd_bluetooth "$@" ;;
        camera|cam)             cmd_camera "$@" ;;
        info|i)                 cmd_info "$@" ;;
        updates|up|u)           cmd_updates "$@" ;;
        thermal|temp)           cmd_thermal "$@" ;;
        keyboard|kbd|keys)      cmd_keyboard "$@" ;;
        sleep|suspend)          cmd_sleep "$@" ;;
        dual-boot|dualboot|db)  cmd_dualboot "$@" ;;
        help|-h|--help)         cmd_help ;;
        *)
            err "Unknown command: $cmd"
            cmd_help
            exit 1
            ;;
    esac
}

main "$@"
